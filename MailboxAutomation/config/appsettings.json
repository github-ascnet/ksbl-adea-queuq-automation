{
  "Paths": {
    "QueueRoot": "queues",
    "StatePath": "state",
    "LogPath": "logs"
  },
  "Queue": {
    "StaleLockMinutes": 60
  },
  "CsvDelimiter": ";",
  "Logging": {
    "ConsoleEnabled": true,
    "FileEnabled": true,
    "EventLogEnabled": false,
    "Level": "INFO",
    "VerboseLogging": false,
    "LogFileName": "jobprocessor.log",
    "EventSource": "MailboxAutomation"
  },
  "EventLog": {
    "LogName": "Application",
    "Source": "MailboxAutomation"
  },
  "Notifications": {
    "Enabled": false,
    "SmtpServer": "",
    "Port": 25,
    "From": "",
    "To": []
  },
  "WhatIfDefault": true,
  "ExchangeOnline": {
    "Enabled": false,
    "TenantDomain": "",
    "Organization": "",
    "AppId": "",
    "CertificateThumbprint": ""
  },
  "ExchangeOnPrem": {
    "Enabled": true
  },
  "ActiveDirectory": {
    "Enabled": true
  }
}
