{
  "Paths": {
    "QueueRoot": "queues",
    "StatePath": "state",
    "LogPath": "logs"
  },
  "Queue": {
    "StaleLockMinutes": 60
  },
  "CsvDelimiter": ";",
  "Logging": {
    "ConsoleEnabled": true,
    "FileEnabled": true,
    "EventLogEnabled": false,
    "Level": "INFO",
    "VerboseLogging": false,
    "LogFileName": "jobprocessor.log",
    "EventSource": "MailboxAutomation"
  },
  "EventLog": {
    "LogName": "Application",
    "Source": "MailboxAutomation"
  },
  "Notifications": {
    "Enabled": false,
    "SendSuccess": true,
    "SendFailure": true,
    "From": "noreply@example.local",
    "To": ["admin@example.local"],
    "SmtpServer": "smtp.example.local",
    "Port": 25,
    "UseSsl": false
  },
  "WhatIfDefault": true,
  "ExchangeOnline": {
    "Enabled": false,
    "TenantDomain": "",
    "Organization": "",
    "AppId": "",
    "CertificateThumbprint": ""
  },
  "ExchangeOnPrem": {
    "Enabled": true,
    "DefaultMailboxDatabases": [],
    "PrimaryMailDomain": "example.test"
  },
  "ActiveDirectory": {
    "Enabled": true
  },
  "Hospis": {
    "ArchiveRoot": "D:\\IAM\\Archive",
    "SqlServerInstance": "",
    "Database": "KSBL_Hospis_Staging",
    "ConnectionString": "",
    "AustrittOOOExternalMessage": "",
    "AustrittOOOInternalMessage": ""
  },
  "PersonMailbox": {
    "PrimaryMailDomain": "example.test",
    "MailboxVisibilityRetryMinutes": 5
  },
  "HomeDirectory": {
    "Enabled": true,
    "DefaultHomeDrive": "H:",
    "CreateFolderIfMissing": true,
    "SetPermissions": true,
    "DefaultAccessRight": "Modify",
    "Inheritance": "ContainerInherit,ObjectInherit",
    "Propagation": "None",
    "NamespaceRoot": "",
    "DefaultTargetRoot": "",
    "FileServers": [],
    "ShareNamePattern": "home_[a-z]",
    "WhatIfShareName": "home_a",
    "DefaultUserDomain": "",
    "ApplicationDirectoryShare": "",
    "DesktopDirectoryShare": "",
    "DfsRootNamePattern": "*\\HomeDrives",
    "DeletedHomeDirectoryMarker": ".delete_manually_user_left_company"
  }
}